{
  "name": "Generic Company Access Portal",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Company Access Portal</title>\n<style>\nbody{font-family:Arial,Helvetica,sans-serif;background:#f7fafc;margin:0}\n.card{max-width:380px;margin:8vh auto;background:#fff;padding:24px;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.06)}\nh1{font-size:18px;margin:0 0 16px}\nlabel{display:block;font-size:12px;margin-top:12px}\ninput{width:100%;padding:10px;border:1px solid #cbd5e1;border-radius:6px}\nbutton{margin-top:16px;width:100%;padding:12px;background:#2563eb;color:#fff;border:none;border-radius:6px;cursor:pointer}\n.small{color:#475569;font-size:12px;margin-top:10px}\n</style>\n</head>\n<body>\n  <div class=\"card\">\n    <h1>Company Access Portal</h1>\n    <form method=\"post\" action=\"\">\n      <label>Email</label>\n      <input name=\"email\" type=\"email\" value=\"{{.Email}}\" required>\n      <label>Password</label>\n      <input name=\"password\" type=\"password\" required>\n      <button type=\"submit\">Continue</button>\n      <div class=\"small\">For authorized users only.</div>\n    </form>\n  </div>\n</body>\n</html>",
  "capture_credentials": true,
  "capture_passwords": true,
  "redirect_url": "https://training.example/teachable"
}